{
  "name": "clinical-trial-protocol-extractor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx evals/harness.ts",
    "eval:cached": "EVAL_VCR=1 tsx evals/harness.ts",
    "eval:cascade": "tsx evals/harness.ts --mode=cascade",
    "eval:cascade:cached": "EVAL_VCR=1 tsx evals/harness.ts --mode=cascade",
    "eval:judge": "tsx evals/harness.ts --scorer=llm --limit=3",
    "build:index": "tsx scripts/build-embedding-index.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.71",
