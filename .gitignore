# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# observability log (sqlite)
logs/*.sqlite
logs/*.sqlite-journal
logs/*.sqlite-wal
logs/*.sqlite-shm

# RAG embedding index (large, regenerated with pnpm build:index)
fixtures/embeddings.json

# Claude Code local workspace (agents, worktrees, settings overrides)
.claude/

# VCR cache (eval replay, gitignored — regenerate with EVAL_VCR=1)
evals/cache/
